import { useState, useMemo, useCallback } from “react”;

// ─── PHYSICS ENGINE ───────────────────────────────────────────
// Stefan-Boltzmann: P_rad = ε σ A T⁴
// Compute power → waste heat fraction → required radiator area
// Constraint: radiator mass vs. launch cost vs. compute density

const STEFAN_BOLTZMANN = 5.670374419e-8; // W·m⁻²·K⁻⁴
const SOLAR_FLUX_LEO = 1361; // W/m² (average)

function computeThermalState(params) {
const {
computePower_kW,
efficiency,       // fraction of power → useful compute (rest → heat)
radiatorTemp_K,
emissivity,
sinkTemp_K,       // space ~3K, lunar surface ~200-380K
radiatorDensity,  // kg/m² of radiator panel
launchCost,       // $/kg to orbit
computeDensity,   // FLOPS/W
} = params;

const computePower_W = computePower_kW * 1000;
const wasteHeat_W = computePower_W * (1 - efficiency);

// Radiative power per m² = εσ(T_rad⁴ - T_sink⁴)
const radPower_per_m2 =
emissivity * STEFAN_BOLTZMANN * (Math.pow(radiatorTemp_K, 4) - Math.pow(sinkTemp_K, 4));

const radiatorArea_m2 = radPower_per_m2 > 0 ? wasteHeat_W / radPower_per_m2 : Infinity;
const radiatorMass_kg = radiatorArea_m2 * radiatorDensity;
const radiatorLaunchCost = radiatorMass_kg * launchCost;

// Total FLOPS capacity
const usefulPower_W = computePower_W * efficiency;
const totalFLOPS = usefulPower_W * computeDensity * 1e9; // GFLOPS/W → FLOPS

// Compute per radiator area — the key metric
const flopsPerRadiatorM2 = radiatorArea_m2 > 0 ? totalFLOPS / radiatorArea_m2 : 0;

// Cost per PFLOPS
const totalPFLOPS = totalFLOPS / 1e15;
const costPerPFLOPS = totalPFLOPS > 0 ? radiatorLaunchCost / totalPFLOPS : Infinity;

// Solar absorption load (if in LEO, radiator absorbs sunlight too)
const solarLoad_W = radiatorArea_m2 * SOLAR_FLUX_LEO * (1 - emissivity) * 0.5; // half-sky avg

return {
wasteHeat_W,
radPower_per_m2,
radiatorArea_m2,
radiatorMass_kg,
radiatorLaunchCost,
totalFLOPS,
totalPFLOPS,
flopsPerRadiatorM2,
costPerPFLOPS,
solarLoad_W,
netCoolingCapacity_W: (radPower_per_m2 * radiatorArea_m2) - solarLoad_W,
};
}

// Generate phase space sweep
function sweepParameter(baseParams, paramKey, min, max, steps) {
const results = [];
for (let i = 0; i <= steps; i++) {
const val = min + (max - min) * (i / steps);
const params = { …baseParams, [paramKey]: val };
const state = computeThermalState(params);
results.push({ x: val, …state });
}
return results;
}

