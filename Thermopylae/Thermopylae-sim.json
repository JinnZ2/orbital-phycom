import { useState, useMemo, useCallback } from “react”;

// ═══════════════════════════════════════════════════════════════
// PHYSICS CONSTANTS
// ═══════════════════════════════════════════════════════════════
const σ = 5.670374419e-8;   // Stefan-Boltzmann W·m⁻²·K⁻⁴
const k_B = 1.380649e-23;   // Boltzmann J/K
const h = 6.62607015e-34;   // Planck J·s
const c = 2.998e8;          // m/s
const PI = Math.PI;

// ═══════════════════════════════════════════════════════════════
// LAYER 1: BULK RADIATOR (thermal job — unchanged)
// ═══════════════════════════════════════════════════════════════
function computeBulkRadiator(p) {
const P_waste = p.computePower_kW * 1000 * (1 - p.efficiency);
const q_rad = p.emissivity * σ * (Math.pow(p.radTemp_K, 4) - Math.pow(p.sinkTemp_K, 4));
const A_total = q_rad > 0 ? P_waste / q_rad : Infinity;
const mass_rad = A_total * p.radDensity_kgm2;
return { P_waste, q_rad, A_total, mass_rad };
}

// ═══════════════════════════════════════════════════════════════
// LAYER 2: GEOMETRIC CONCENTRATOR (horn/trough)
// Narrows lobe, does NOT increase brightness above T_phys
// Gain = A_aperture / A_throat (limited by diffraction)
// Beam solid angle Ω = λ² / A_aperture
// Power into beam = B_ν(T) × A_throat × Ω_beam × Δν
//   but brightness B_ν capped at Planck @ T_emitter
// ═══════════════════════════════════════════════════════════════
function computeGeometricConcentrator(bulk, p) {
// Wien peak for bulk radiator
const λ_bulk = 2.898e-3 / p.radTemp_K;

// Hot segment: dedicated comms surface run hotter
const T_emit = p.hotSegmentTemp_K;
const λ_emit = 2.898e-3 / T_emit;
const ν_emit = c / λ_emit;

// Hot segment area and thermal cost
const A_hot = p.hotSegmentFraction * bulk.A_total;
const q_hot = p.emissivity * σ * (Math.pow(T_emit, 4) - Math.pow(p.sinkTemp_K, 4));
const P_hot_total = q_hot * A_hot; // total power radiated by hot segment

// Horn geometry
// N horns across the hot segment
// Each horn: throat area A_t, aperture area A_ap
// Geometric gain G = A_ap / A_t (capped by diffraction)
const A_throat_single = p.throatWidth_m * p.throatWidth_m; // square throat
const A_aperture_single = p.hornApertureWidth_m * p.hornApertureWidth_m;
const G_geometric = A_aperture_single / A_throat_single;

// Diffraction limit: max gain = 4π A_ap / λ²
const G_diffraction = (4 * PI * A_aperture_single) / (λ_emit * λ_emit);
const G_effective = Math.min(G_geometric, G_diffraction);

// Number of horns that fit on hot segment
const N_horns = Math.floor(A_hot / A_aperture_single) || 1;

// Beam solid angle per horn
const Ω_beam = (λ_emit * λ_emit) / A_aperture_single;
const beamDiv_rad = Math.sqrt(Ω_beam);
const beamDiv_arcsec = beamDiv_rad * 206265;
const beamDiv_deg = beamDiv_rad * (180 / PI);

// Spectral radiance at emitter temp (Planck, per unit freq)
const hv_kT = (h * ν_emit) / (k_B * T_emit);
const B_ν = (2 * h * Math.pow(ν_emit, 3) / (c * c)) / (Math.exp(hv_kT) - 1);

// Power per horn into beam within modulation bandwidth
// P_horn = B_ν × A_throat × Ω_beam_of_horn × Δν
// But for a horn: the throat radiates into the horn’s solid angle
// which IS the beam. So P_horn = B_ν × A_throat × Δν × (horn captures 2π→Ω)
// Simplified: P per horn into forward lobe ≈ B_ν × A_aperture × Δν × Ω_beam
// Actually: P_directed = B_ν × Δν × λ² (per spatial mode, per polarization)
// With N_horns independent: P_total_directed = N_horns × B_ν × Δν × λ²
const Δν = p.modBW_GHz * 1e9;
const P_per_mode = B_ν * Δν * λ_emit * λ_emit; // single spatial mode
const P_directed_total = N_horns * P_per_mode;

// Combined beam: N_horns doesn’t narrow the beam further unless phased
// Each horn independently beams in ~same direction (structural alignment)
// Total power on target = N_horns × P_per_mode × (A_rx / spot_area)
// Spot area at distance = Ω_beam × d²

// Horn mass overhead
const hornMass_per = p.hornMass_kg;
const totalHornMass = N_horns * hornMass_per;

return {
λ_bulk_um: λ_bulk * 1e6,
λ_emit_um: λ_emit * 1e6,
ν_emit,
T_emit,
A_hot,
P_hot_total,
G_effective,
G_diffraction,
N_horns,
Ω_beam,
beamDiv_arcsec,
beamDiv_deg,
B_ν,
P_per_mode,
P_directed_total,
totalHornMass,
Δν,
};
}

// ═══════════════════════════════════════════════════════════════
// LAYER 3: ACTIVE MODULATOR
// Emissivity switching at throat → information encoding
// Capacity = BW × log2(1 + SNR)
// SNR limited by: thermal noise at receiver, modulation depth
// ═══════════════════════════════════════════════════════════════
function computeActiveModulator(geom, p) {
const d_m = p.distance_km * 1000;

// Spot area at distance (per horn)
const spotArea = geom.Ω_beam * d_m * d_m;

// Capture fraction
const captureFrac = Math.min(1, p.rxArea_m2 / spotArea);

// Received power (all horns, aligned)
const P_rx = geom.P_directed_total * captureFrac;

// Modulation: emissivity switches between ε_high and ε_low
// Signal power = P_rx × modulation_depth
const modDepth = p.modDepthFrac; // ε_high - ε_low / ε_high
const P_signal = P_rx * modDepth;

// Noise: receiver thermal + shot noise
// Thermal: N = k_B × T_rx × BW
const N_thermal = k_B * p.rxTemp_K * geom.Δν;

// Shot noise (photon counting regime for mid-IR)
// N_shot = h × ν × P_rx (simplified)
const N_shot = h * geom.ν_emit * P_rx;

const N_total = N_thermal + N_shot;

const SNR = P_signal / N_total;
const SNR_dB = 10 * Math.log10(Math.max(SNR, 1e-30));

// Shannon capacity
// But actual modulation rate limited by switching speed
const switchRate_Hz = p.switchRate_kHz * 1000;
// Nyquist: max symbol rate = switchRate
// With OOK: ~1 bit per symbol at low SNR, log2(1+SNR) at high
const bitsPerSymbol = Math.log2(1 + Math.max(SNR, 0));
const capacity_bps = switchRate_Hz * bitsPerSymbol;

// Shannon limit (if modulation could use full BW)
const shannonLimit = geom.Δν * Math.log2(1 + Math.max(SNR, 0));

// Modulator mass and power
// VO₂ film: ~0.1 kg per throat, ~1W switching power
// MEMS: ~0.05 kg, ~0.5W
// Electrochromic: ~0.2 kg, ~0.1W
const modMass = geom.N_horns * p.modMassPerThroat_kg;
const modPower = geom.N_horns * p.modPowerPerThroat_W;

// ─── X-BAND COMPARISON ───────────────────────────────────
const xb_freq = 8e9;
const xb_λ = c / xb_freq;
const xb_dish = 3.0;
const xb_A = PI * (xb_dish / 2) ** 2;
const xb_gain = (4 * PI * xb_A) / (xb_λ ** 2);
const xb_P = 100;
const xb_EIRP = xb_P * xb_gain;
const xb_rxP = (xb_EIRP / (4 * PI * d_m * d_m)) * p.rxArea_m2;
const xb_BW = 500e6;
const xb_N = k_B * p.rxTemp_K * xb_BW;
const xb_SNR = xb_rxP / xb_N;
const xb_cap = xb_BW * Math.log2(1 + Math.max(xb_SNR, 0));
const xb_mass = 45;
const xb_power = 150; // TWTA + electronics

// Total dual-use overhead
const dualUseMass = geom.totalHornMass + modMass;
const dualUsePower = modPower;

return {
spotArea, captureFrac,
P_rx, P_signal, N_thermal, N_shot, N_total,
SNR, SNR_dB,
capacity_bps, shannonLimit, bitsPerSymbol,
modMass, modPower, dualUseMass, dualUsePower,
// x-band
xb_cap, xb_mass, xb_power, xb_SNR_dB: 10 * Math.log10(Math.max(xb_SNR, 1e-30)),
// ratios
massSaved: xb_mass - dualUseMass,
powerSaved: xb_power - dualUsePower,
bpsPerKg_dual: capacity_bps / (dualUseMass || 0.01),
bpsPerKg_xband: xb_cap / xb_mass,
};
}

// ═══════════════════════════════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════════════════════════════
const fmt = (n, d = 1) => {
if (!isFinite(n)) return “∞”;
const abs = Math.abs(n);
if (abs >= 1e15) return (n / 1e15).toFixed(d) + “P”;
if (abs >= 1e12) return (n / 1e12).toFixed(d) + “T”;
if (abs >= 1e9) return (n / 1e9).toFixed(d) + “G”;
if (abs >= 1e6) return (n / 1e6).toFixed(d) + “M”;
if (abs >= 1e3) return (n / 1e3).toFixed(d) + “k”;
return n.toFixed(d);
};
const fmtBits = (b) => {
if (!isFinite(b) || b <= 0) return “0 bps”;
if (b >= 1e12) return (b / 1e12).toFixed(1) + “ Tbps”;
if (b >= 1e9) return (b / 1e9).toFixed(1) + “ Gbps”;
if (b >= 1e6) return (b / 1e6).toFixed(1) + “ Mbps”;
if (b >= 1e3) return (b / 1e3).toFixed(1) + “ kbps”;
return b.toFixed(0) + “ bps”;
};
const fmtCost = (n) => {
if (!isFinite(n)) return “∞”;
if (n >= 1e9) return “$” + (n / 1e9).toFixed(1) + “B”;
if (n >= 1e6) return “$” + (n / 1e6).toFixed(1) + “M”;
if (n >= 1e3) return “$” + (n / 1e3).toFixed(1) + “k”;
return “$” + n.toFixed(0);
};

function MiniChart({ data, xKey, yKey, xLabel, yLabel, color, highlight, logY }) {
const W = 300, H = 120, P = 30;
const xs = data.map(d => d[xKey]);
const rawYs = data.map(d => { const v = d[yKey]; return isFinite(v) ? v : 0; });
const ys = logY ? rawYs.map(v => v > 0 ? Math.log10(v) : 0) : rawYs;
const xMn = Math.min(…xs), xMx = Math.max(…xs);
const yMn = Math.min(…ys), yMx = Math.max(…ys);
const sx = v => P + ((v - xMn) / (xMx - xMn || 1)) * (W - P * 2);
const sy = v => H - P - ((v - yMn) / (yMx - yMn || 1)) * (H - P * 2);
const pathD = data.map((d, i) => {
const y = logY ? (rawYs[i] > 0 ? Math.log10(rawYs[i]) : 0) : rawYs[i];
return `${i === 0 ? "M" : "L"}${sx(d[xKey])},${sy(y)}`;
}).join(” “);
const hIdx = data.reduce((b, d, i) => Math.abs(d[xKey] - highlight) < Math.abs(data[b][xKey] - highlight) ? i : b, 0);
const hy = logY ? (rawYs[hIdx] > 0 ? Math.log10(rawYs[hIdx]) : 0) : rawYs[hIdx];
return (
<svg viewBox={`0 0 ${W} ${H}`} style={{ width: “100%”, maxWidth: 340, height: “auto” }}>
{[.25, .5, .75].map(f => <line key={f} x1={P} x2={W - P} y1={sy(yMn + f * (yMx - yMn))} y2={sy(yMn + f * (yMx - yMn))} stroke=”#1a2a3a” strokeWidth={0.5} />)}
<path d={pathD} fill="none" stroke={color} strokeWidth={2} opacity={0.9} />
<path d={pathD} fill="none" stroke={color} strokeWidth={5} opacity={0.12} />
<circle cx={sx(data[hIdx][xKey])} cy={sy(hy)} r={4.5} fill={color} />
<circle cx={sx(data[hIdx][xKey])} cy={sy(hy)} r={9} fill={color} opacity={0.15} />
<text x={W / 2} y={H - 3} textAnchor=“middle” fill=”#5a7a8a” fontSize={8} fontFamily=“monospace”>{xLabel}</text>
<text x={3} y={H / 2} textAnchor=“middle” fill=”#5a7a8a” fontSize={8} fontFamily=“monospace” transform={`rotate(-90,3,${H / 2})`}>{yLabel}</text>
</svg>
);
}

function CompBar({ l1, v1, l2, v2, c1, c2, u }) {
const mx = Math.max(Math.abs(v1), Math.abs(v2), 1e-30);
return (
<div style={{ marginBottom: 8 }}>
<div style={{ display: “flex”, justifyContent: “space-between”, fontSize: 9, color: “#4a6a7a”, marginBottom: 2 }}>
<span>{l1}: <b style={{ color: c1 }}>{u(v1)}</b></span>
<span>{l2}: <b style={{ color: c2 }}>{u(v2)}</b></span>
</div>
<div style={{ display: “flex”, gap: 2, height: 10, borderRadius: 3, background: “#0a0e14” }}>
<div style={{ width: `${(Math.abs(v1) / mx) * 100}%`, background: `linear-gradient(90deg,${c1}40,${c1})`, borderRadius: “3px 0 0 3px”, minWidth: 2, transition: “width 0.3s” }} />
<div style={{ width: `${(Math.abs(v2) / mx) * 100}%`, background: `linear-gradient(90deg,${c2}40,${c2})`, borderRadius: “0 3px 3px 0”, minWidth: 2, transition: “width 0.3s” }} />
</div>
</div>
);
}

function Slider({ k, label, unit, min, max, step, value, onChange, accent = “#00ccaa” }) {
return (
<div style={{ marginBottom: 9 }}>
<div style={{ display: “flex”, justifyContent: “space-between”, marginBottom: 1 }}>
<span style={{ fontSize: 10, color: “#5a7a8a” }}>{label}</span>
<span style={{ fontSize: 10, color: accent, fontWeight: 600 }}>{value}{unit ? ` ${unit}` : “”}</span>
</div>
<input type=“range” min={min} max={max} step={step} value={value}
onChange={e => onChange(k, parseFloat(e.target.value))}
style={{ width: “100%”, height: 20, accentColor: accent, cursor: “pointer” }} />
</div>
);
}

