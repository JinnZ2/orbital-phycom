// ═══════════════════════════════════════════════════════════════
// MAIN COMPONENT
// ═══════════════════════════════════════════════════════════════
export default function ThermopylaeSimulator() {
const [params, setParams] = useState(SCENARIOS[“GEO Downlink”]);
const [tab, setTab] = useState(“overview”); // overview | layers | sweep | compare
const [activeScenario, setActiveScenario] = useState(“GEO Downlink”);
const [sweepKey, setSweepKey] = useState(“hotSegmentTemp_K”);

const setP = useCallback((k, v) => { setParams(p => ({ …p, [k]: v })); setActiveScenario(null); }, []);

const bulk = useMemo(() => computeBulkRadiator(params), [params]);
const geom = useMemo(() => computeGeometricConcentrator(bulk, params), [bulk, params]);
const mod = useMemo(() => computeActiveModulator(geom, params), [geom, params]);

// Sweep data
const allParamDefs = […L1_PARAMS, …L2_PARAMS, …L3_PARAMS];
const sweepDef = allParamDefs.find(p => p.key === sweepKey) || L2_PARAMS[0];
const sweepData = useMemo(() => {
const out = [];
for (let i = 0; i <= 80; i++) {
const val = sweepDef.min + (sweepDef.max - sweepDef.min) * (i / 80);
const sp = { …params, [sweepKey]: val };
const b = computeBulkRadiator(sp);
const g = computeGeometricConcentrator(b, sp);
const m = computeActiveModulator(g, sp);
out.push({ x: val, capacity: m.capacity_bps, SNR_dB: m.SNR_dB, radArea: b.A_total, P_rx: m.P_rx });
}
return out;
}, [params, sweepKey, sweepDef]);

const S = {
box: { background: “#0d1520”, border: “1px solid #1a2a3a”, borderRadius: 4, padding: “6px 8px” },
lbl: { fontSize: 9, color: “#3a5a6a”, textTransform: “uppercase”, letterSpacing: 0.8 },
val: { fontSize: 14, color: “#e0f0f4”, fontWeight: 600, marginTop: 2 },
sub: { fontSize: 9, color: “#4a6a7a”, marginTop: 1 },
};

const tabBtn = (t, label) => (
<button onClick={() => setTab(t)} style={{
flex: 1, padding: “7px 0”, textAlign: “center”, fontSize: 10, fontWeight: 600,
color: tab === t ? “#00ccaa” : “#3a5a6a”, background: tab === t ? “#00ccaa08” : “transparent”,
border: “none”, borderBottom: `2px solid ${tab === t ? "#00ccaa" : "#1a2a3a"}`,
cursor: “pointer”, fontFamily: “inherit”,
}}>{label}</button>
);

// Layer health indicators
const thermalOk = bulk.q_rad > 0 && isFinite(bulk.A_total);
const commsViable = mod.SNR > 1;
const dualWin = mod.massSaved > 0;

return (
<div style={{
background: “#0a0e14”, color: “#c0d0d8”, minHeight: “100vh”,
fontFamily: “‘JetBrains Mono’,‘Fira Code’,‘SF Mono’,monospace”,
fontSize: 13, padding: “12px 10px”, maxWidth: 420, margin: “0 auto”,
}}>
{/* Header */}
<div style={{ borderBottom: “1px solid #1a2a3a”, paddingBottom: 8, marginBottom: 10 }}>
<div style={{ fontSize: 14, color: “#00ccaa”, fontWeight: 700, letterSpacing: 1.5 }}>
THERMOPYLAE
</div>
<div style={{ fontSize: 9, color: “#3a5a6a”, marginTop: 2 }}>
Three-layer dual-use: bulk radiator → horn concentrator → active modulator
</div>
</div>

```
