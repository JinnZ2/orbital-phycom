import { useState, useMemo, useCallback } from “react”;

// ═══════════════════════════════════════════════════════════════
// CONSTANTS & PHYSICS
// ═══════════════════════════════════════════════════════════════
const σ = 5.670374419e-8;
const k_B = 1.380649e-23;
const h_p = 6.62607015e-34;
const c = 2.998e8;

// ═══════════════════════════════════════════════════════════════
// PLATFORM ENGINE — 4-stage joule lifecycle
// ═══════════════════════════════════════════════════════════════
function computePlatform(p) {
const P_in = p.totalPower_kW * 1000;
const N = p.numNodes;
const P_per_node = P_in / N;

// ━━━ STAGE 1: COMPUTE + LOCAL THERMAL WORK ━━━━━━━━━━━━━━
const P_compute = P_in * p.computeEff;
const P_waste = P_in * (1 - p.computeEff);
const P_per_node_waste = P_waste / N;

// Reuse 1a: Phase-change store → eclipse survival
const eclipseHeaterReplaced_W = p.eclipseHeaterPerNode_W * N;
// PCM capacity: paraffin ~200 kJ/kg
const eclipseDuration_s = p.eclipseDuration_min * 60;
const pcmMassNeeded_kg = (eclipseHeaterReplaced_W * eclipseDuration_s) / (p.pcmLatentHeat_kJkg * 1000);

// Reuse 1b: Thermal health monitoring (value, not power)
const healthMonitorNodes = N; // each node self-diagnosing

const P_after_S1 = P_waste; // all waste heat enters cluster bus
const S1_reuse_W = eclipseHeaterReplaced_W;

// ━━━ STAGE 2: CLUSTER THERMAL BUS ━━━━━━━━━━━━━━━━━━━━━━
// Reuse 2a: Propellant depot warming
const P_prop_heating = p.propHeating_kW * 1000;

// Reuse 2b: High-T stage → TPV conversion
const P_to_highT = p.tpvInputPower_kW * 1000;
const T_highT = p.tpvBlockTemp_K;
// TPV at ~1.55μm, efficiency depends on temp
const tpvEff = p.tpvEfficiency;
const P_tpv_electric = P_to_highT * tpvEff;
const P_tpv_waste = P_to_highT * (1 - tpvEff);

// TPV electric feeds: beacon + thruster valves
const P_beacon_from_tpv = P_tpv_electric * 0.6;
const P_valves_from_tpv = P_tpv_electric * 0.4;

// Reuse 2c: Attitude louvers (thermal actuators)
const P_attitude_thermal = p.attitudeLouver_W;
const attitudeRate_deghr = p.attitudeRate_deghr;

const P_after_S2 = P_after_S1 - P_prop_heating - P_to_highT - P_attitude_thermal;
const S2_reuse_W = P_prop_heating + P_tpv_electric + P_attitude_thermal;

// ━━━ STAGE 3: RADIATOR + STRUCTURED EXPORT ━━━━━━━━━━━━━
const P_to_radiators = Math.max(0, P_after_S2 + P_tpv_waste);
const numTiles = p.numTiles;
const tileArea_m2 = p.tileArea_m2;
const A_total = numTiles * tileArea_m2;

// Hot gates: 10% of tile area
const hotGateFrac = p.hotGateFrac;
const A_hotgates = A_total * hotGateFrac;
const A_bulk = A_total * (1 - hotGateFrac);

// Hot gate beam properties
const T_rad = p.radTemp_K;
const λ_peak = 2.898e-3 / T_rad;
const troughLength_m = p.troughLength_m;
const coneAngle_deg = p.coneAngle_deg;
const coneAngle_rad = coneAngle_deg * Math.PI / 180;

// Power per tile into directed cone
const q_rad = p.emissivity * σ * (Math.pow(T_rad, 4) - Math.pow(p.sinkTemp_K, 4));
const P_per_tile_total = q_rad * tileArea_m2;
const P_per_tile_hotgate = q_rad * tileArea_m2 * hotGateFrac;
// Geometric concentration: horn narrows from 2π to cone
const Ω_cone = 2 * Math.PI * (1 - Math.cos(coneAngle_rad));
const geomGain = (2 * Math.PI) / Ω_cone;
const P_per_tile_directed = P_per_tile_hotgate; // same power, narrower beam
const P_beacon_total = P_per_tile_directed * numTiles * p.beaconModEff;

// Beacon data rate
const beaconBitrate_bps = p.beaconBitrate_bps;

// Reuse 3b: Tile-edge thermal diodes → diagnostics
const diagnosticTiles = numTiles;

// Reuse 3c: Docking radiator utility
const dockingTiles = p.dockingTiles;
const dockingCapacity_W = dockingTiles * P_per_tile_total;

const S3_reuse_W = P_beacon_total + dockingCapacity_W;

// ━━━ STAGE 4: FINAL ENTROPY DUMP ━━━━━━━━━━━━━━━━━━━━━━━
const P_final_dump = P_to_radiators - P_beacon_total;
const A_dump = A_bulk;
// Edge shields reduce albedo reflection
const albedoReduction_pct = p.edgeShieldEff * 100;

// Calibration source utility
const calSourcePower = P_final_dump; // known signature

// ━━━ TOTALS ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
const totalReuse_W = S1_reuse_W + S2_reuse_W + S3_reuse_W;
const reuseRatio = totalReuse_W / P_waste;
const servicesPerJoule = (
(S1_reuse_W > 0 ? 2 : 0) + // eclipse + health
(S2_reuse_W > 0 ? 3 : 0) + // prop + TPV + attitude
(S3_reuse_W > 0 ? 3 : 0) + // beacon + diag + docking
1 // cal source
);

// ━━━ 1MW SCALING WALL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
const P_MW = p.totalPower_kW / 1000; // in MW
const scalingIssues = [];
if (P_in > 200000) scalingIssues.push({ issue: “Two-phase flow required”, severity: “critical”, detail: “Single-phase loop pressure drop exceeds pump limits” });
if (P_in > 300000) scalingIssues.push({ issue: “Active gate coherence”, severity: “critical”, detail: “Passive geometry can’t maintain beam quality at this scale” });
if (P_in > 150000) scalingIssues.push({ issue: “Thermal customer exhaustion”, severity: “warning”, detail: “Onboard reuse saturates — excess heat has no secondary use” });
if (A_total > 2000) scalingIssues.push({ issue: “Structural mass”, severity: “warning”, detail: “Radiator array exceeds single-vehicle deployment limits” });
if (P_in > 500000) scalingIssues.push({ issue: “Distribute or die”, severity: “critical”, detail: “Must split across multiple vehicles — swarm architecture required” });

// Reuse saturation: what fraction of waste has a customer?
const reuseSaturation = Math.min(1, totalReuse_W / P_waste);
// At higher power, customers don’t scale
const projectedSaturation_1MW = Math.min(1, totalReuse_W / (1e6 * (1 - p.computeEff)));

return {
P_in, N, P_compute, P_waste, P_per_node_waste,
// S1
eclipseHeaterReplaced_W, pcmMassNeeded_kg, healthMonitorNodes,
S1_reuse_W, P_after_S1,
// S2
P_prop_heating, P_to_highT, T_highT, tpvEff,
P_tpv_electric, P_beacon_from_tpv, P_valves_from_tpv,
P_attitude_thermal, attitudeRate_deghr,
S2_reuse_W, P_after_S2,
// S3
P_to_radiators, numTiles, tileArea_m2, A_total,
A_hotgates, A_bulk, T_rad, λ_peak: λ_peak * 1e6,
geomGain, P_beacon_total, beaconBitrate_bps,
dockingCapacity_W, diagnosticTiles,
S3_reuse_W,
// S4
P_final_dump, A_dump, albedoReduction_pct, calSourcePower,
// Totals
totalReuse_W, reuseRatio, servicesPerJoule,
mass_radiator: A_total * p.radDensity_kgm2,
// Scaling
scalingIssues, reuseSaturation, projectedSaturation_1MW,
};
}

// ═══════════════════════════════════════════════════════════════
// DEFAULTS
// ═══════════════════════════════════════════════════════════════
const DEFAULTS = {
totalPower_kW: 100, numNodes: 10, computeEff: 0.15,
// S1
eclipseHeaterPerNode_W: 50, eclipseDuration_min: 30,
pcmLatentHeat_kJkg: 200,
// S2
propHeating_kW: 2, tpvInputPower_kW: 5, tpvBlockTemp_K: 550,
tpvEfficiency: 0.15, attitudeLouver_W: 200, attitudeRate_deghr: 1.5,
// S3
numTiles: 20, tileArea_m2: 25, hotGateFrac: 0.10,
radTemp_K: 335, emissivity: 0.92, sinkTemp_K: 3,
troughLength_m: 1.0, coneAngle_deg: 15,
beaconModEff: 0.02, beaconBitrate_bps: 100,
dockingTiles: 4, radDensity_kgm2: 5,
// S4
edgeShieldEff: 0.85,
};

const SCENARIOS = {
“100kW SSO”: { …DEFAULTS },
“200kW Higher Eff”: { …DEFAULTS, totalPower_kW: 200, computeEff: 0.20, numTiles: 30, tpvInputPower_kW: 8 },
“50kW Compact”: { …DEFAULTS, totalPower_kW: 50, numNodes: 5, numTiles: 12, tileArea_m2: 20, tpvInputPower_kW: 2.5, propHeating_kW: 1 },
“500kW Scaling”: { …DEFAULTS, totalPower_kW: 500, numNodes: 20, numTiles: 60, tpvInputPower_kW: 15, propHeating_kW: 5 },
“1MW Wall”: { …DEFAULTS, totalPower_kW: 1000, numNodes: 40, numTiles: 100, tpvInputPower_kW: 20, propHeating_kW: 8 },
};

// ═══════════════════════════════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════════════════════════════
const fmt = (n, d = 1) => {
if (!isFinite(n)) return “∞”;
const a = Math.abs(n);
if (a >= 1e6) return (n / 1e6).toFixed(d) + “M”;
if (a >= 1e3) return (n / 1e3).toFixed(d) + “k”;
if (a < 0.01 && a > 0) return (n * 1000).toFixed(d) + “m”;
return n.toFixed(d);
};
const pct = v => (v * 100).toFixed(1) + “%”;
const fW = w => {
if (w >= 1e6) return (w / 1e6).toFixed(1) + “ MW”;
if (w >= 1e3) return (w / 1e3).toFixed(1) + “ kW”;
if (w >= 1) return w.toFixed(1) + “ W”;
return (w * 1000).toFixed(0) + “ mW”;
};

function Sl({ k, label, unit, min, max, step, value, onChange, accent = “#00ccaa” }) {
return (
<div style={{ marginBottom: 7 }}>
<div style={{ display: “flex”, justifyContent: “space-between”, marginBottom: 1 }}>
<span style={{ fontSize: 9, color: “#5a7a8a” }}>{label}</span>
<span style={{ fontSize: 9, color: accent, fontWeight: 600 }}>
{typeof value === ‘number’ ? (Number.isInteger(step) && step >= 1 ? value : value.toFixed(2)) : value}{unit ? ` ${unit}` : “”}
</span>
</div>
<input type=“range” min={min} max={max} step={step} value={value}
onChange={e => onChange(k, parseFloat(e.target.value))}
style={{ width: “100%”, height: 18, accentColor: accent, cursor: “pointer” }} />
</div>
);
}

// Sankey-ish horizontal flow
function JouleFlow({ stages }) {
const total = stages[0]?.input || 1;
return (
<div style={{ marginBottom: 10 }}>
{stages.map((s, i) => {
const inputW = (s.input / total) * 100;
const reuseW = (s.reuse / total) * 100;
const passW = inputW - reuseW;
return (
<div key={i} style={{ marginBottom: 3 }}>
<div style={{ display: “flex”, alignItems: “center”, gap: 4, marginBottom: 2 }}>
<div style={{
width: 14, height: 14, borderRadius: 2, background: `${s.color}25`,
display: “flex”, alignItems: “center”, justifyContent: “center”,
fontSize: 8, color: s.color, fontWeight: 700,
}}>S{i + 1}</div>
<span style={{ fontSize: 8, color: s.color, fontWeight: 600, flex: 1 }}>{s.label}</span>
<span style={{ fontSize: 8, color: “#4a6a7a” }}>{fW(s.reuse)} extracted</span>
</div>
<div style={{ display: “flex”, height: 10, borderRadius: 2, overflow: “hidden”, background: “#0a0e14” }}>
<div style={{
width: `${Math.max(0.5, reuseW)}%`,
background: `linear-gradient(90deg, ${s.color}60, ${s.color})`,
transition: “width 0.3s”,
}} />
<div style={{
width: `${Math.max(0.5, passW)}%`,
background: `${s.color}15`,
transition: “width 0.3s”,
}} />
</div>
</div>
);
})}
</div>
);
}

// Service list
function SvcRow({ name, value, detail, color }) {
return (
<div style={{ display: “flex”, justifyContent: “space-between”, alignItems: “baseline”, fontSize: 9, padding: “3px 0”, borderBottom: “1px solid #0a0e1488” }}>
<div>
<span style={{ color: “#5a7a8a” }}>{name}</span>
{detail && <span style={{ color: “#3a4a5a”, fontSize: 8, marginLeft: 4 }}>{detail}</span>}
</div>
<span style={{ color, fontWeight: 600 }}>{value}</span>
</div>
);
}

