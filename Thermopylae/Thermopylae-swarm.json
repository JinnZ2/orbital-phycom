import { useState, useMemo, useCallback, useEffect, useRef } from “react”;

// ═══════════════════════════════════════════════════════════════
// CONSTANTS
// ═══════════════════════════════════════════════════════════════
const σ = 5.670374419e-8;

// ═══════════════════════════════════════════════════════════════
// NODE ENGINE — each node is a 100kW-class platform
// ═══════════════════════════════════════════════════════════════
function computeNode(p, workloadFrac, radiatorDamage, receivedHeat, exportedHeat) {
const P_in = p.nodePower_kW * 1000 * workloadFrac;
const P_compute = P_in * p.computeEff;
const P_waste = P_in * (1 - p.computeEff);

// Stage 1-2: internal reuse (same as single platform)
const P_eclipse = p.eclipseHeater_W;
const P_prop = p.propHeating_W;
const P_tpv_in = p.tpvInput_W;
const P_tpv_out = P_tpv_in * p.tpvEff;
const P_attitude = p.attitudeLouver_W;
const P_internal_reuse = P_eclipse + P_prop + P_tpv_out + P_attitude;
const P_to_rad = Math.max(0, P_waste - P_prop - P_tpv_in - P_attitude + (P_tpv_in * (1 - p.tpvEff)));

// Radiator capacity (with damage)
const A_total = p.tilesPerNode * p.tileArea_m2;
const A_effective = A_total * (1 - radiatorDamage);
const q_rad = p.emissivity * σ * (Math.pow(p.radTemp_K, 4) - Math.pow(p.sinkTemp_K, 4));
const P_rad_capacity = q_rad * A_effective;

// Thermal balance
const P_need_to_dump = P_to_rad + receivedHeat;
const P_actually_dumped = Math.min(P_need_to_dump, P_rad_capacity) + exportedHeat;
const thermalMargin = P_rad_capacity > 0 ? 1 - (P_need_to_dump / P_rad_capacity) : -1;
const isOverheating = thermalMargin < 0;

// Hot gate comms
const A_hotgate = A_effective * p.hotGateFrac;
const P_beacon = A_hotgate * q_rad * p.beaconModEff;

return {
P_in, P_compute, P_waste, P_internal_reuse, P_to_rad,
A_total, A_effective, P_rad_capacity, P_need_to_dump,
thermalMargin, isOverheating, P_beacon,
workloadFrac, radiatorDamage,
};
}

// ═══════════════════════════════════════════════════════════════
// SWARM ENGINE — federation, leasing, resilience
// ═══════════════════════════════════════════════════════════════
function computeSwarm(p, nodeStates) {
const N = p.numNodes;

// Per-node compute with workload and damage
const nodes = [];
let totalCompute = 0, totalWaste = 0, totalReuse = 0;
let totalRadCap = 0, totalRadNeed = 0;
let totalBeacon = 0;
let hotNodes = [], coldNodes = [];

for (let i = 0; i < N; i++) {
const ns = nodeStates[i] || { workload: 1.0, damage: 0 };
const node = computeNode(p, ns.workload, ns.damage, 0, 0);
nodes.push(node);
totalCompute += node.P_compute;
totalWaste += node.P_waste;
totalReuse += node.P_internal_reuse;
totalRadCap += node.P_rad_capacity;
totalRadNeed += node.P_need_to_dump;
totalBeacon += node.P_beacon;
if (node.thermalMargin < 0.1) hotNodes.push(i);
if (node.thermalMargin > 0.3) coldNodes.push(i);
}

// ── THERMAL LEASING ──────────────────────────────────────
// Hot nodes export to cold nodes
let thermalTransfers = [];
let totalLeased = 0;
const hotCopy = […hotNodes];
const coldCopy = […coldNodes];

for (const hi of hotCopy) {
if (coldCopy.length === 0) break;
const hotNode = nodes[hi];
const deficit = hotNode.P_need_to_dump - hotNode.P_rad_capacity;
if (deficit <= 0) continue;

```
const ci = coldCopy[0];
const coldNode = nodes[ci];
const surplus = coldNode.P_rad_capacity - coldNode.P_need_to_dump;
const transfer = Math.min(deficit, surplus * 0.8, p.maxIRTransfer_W);

if (transfer > 0) {
  thermalTransfers.push({ from: hi, to: ci, power: transfer });
  totalLeased += transfer;
  // Update margins conceptually
  nodes[hi] = { ...nodes[hi], thermalMargin: nodes[hi].thermalMargin + transfer / nodes[hi].P_rad_capacity };
  nodes[ci] = { ...nodes[ci], thermalMargin: nodes[ci].thermalMargin - transfer / nodes[ci].P_rad_capacity };
  if (nodes[ci].thermalMargin < 0.3) coldCopy.shift();
}
```

}

// ── WORKLOAD FEDERATION ──────────────────────────────────
// Overheating nodes shed compute to cold neighbors
let workloadMigrations = [];
for (const hi of hotNodes) {
if (nodes[hi].thermalMargin < 0 && coldNodes.length > 0) {
const shedFrac = Math.min(0.3, -nodes[hi].thermalMargin);
const target = coldNodes[0];
workloadMigrations.push({ from: hi, to: target, fraction: shedFrac });
}
}

// ── RESILIENCE ───────────────────────────────────────────
// If node loses radiator, compute redistributes
const damagedNodes = nodeStates.filter(ns => ns.damage > 0).length;
const totalDamage = nodeStates.reduce((s, ns) => s + ns.damage, 0) / N;
const effectiveCapacity = 1 - (totalDamage * 0.5); // graceful degradation
const capacityLossPerNode = damagedNodes > 0 ? (totalDamage / N) : 0;

// ── IR RANGING MESH ──────────────────────────────────────
// N nodes → N(N-1)/2 baselines
const numBaselines = N * (N - 1) / 2;
const maxBaseline_m = p.formationSpacing_m * 1.5;
// Angular resolution: λ/D where D = max baseline
const λ_peak = 2.898e-3 / p.radTemp_K;
const angularRes_rad = λ_peak / maxBaseline_m;
const angularRes_arcsec = angularRes_rad * 206265;
// Ranging precision: ~λ/SNR
const rangingPrecision_mm = (λ_peak / 100) * 1000; // assume SNR~100

// ── HOT GATE LINK BUDGET ─────────────────────────────────
const d_link = p.formationSpacing_m;
const λ_m = λ_peak;
const freeSpaceLoss_dB = 20 * Math.log10(4 * Math.PI * d_link / λ_m);
const photonsPerBit = 1e4; // spec: 10⁴ photons/bit
const linkBitrate = p.gateBitrate_bps;
// 8-bit node ID + 8-bit thermal margin, repeated
const frameSize_bits = 16;
const frameRate = linkBitrate / frameSize_bits;

// ── THERMAL ECONOMY ──────────────────────────────────────
const swarmMarginAvg = nodes.reduce((s, n) => s + n.thermalMargin, 0) / N;
const swarmMarginMin = Math.min(…nodes.map(n => n.thermalMargin));
const swarmMarginMax = Math.max(…nodes.map(n => n.thermalMargin));
const headroom = swarmMarginAvg;

// Revenue model: excess capacity as tradeable asset
const excessCooling_W = Math.max(0, totalRadCap - totalRadNeed);
const coolingPrice_per_W = 0.001; // $/W/hr hypothetical
const hourlyRevenue = excessCooling_W * coolingPrice_per_W;

// ── 10MW SCALING ─────────────────────────────────────────
const swarms_for_10MW = 10;
const total_10MW_nodes = N * swarms_for_10MW;
const total_10MW_area = totalRadCap / q_rad_helper(p) * swarms_for_10MW;
const total_10MW_baselines = total_10MW_nodes * (total_10MW_nodes - 1) / 2;

return {
nodes, N,
totalCompute, totalWaste, totalReuse,
totalRadCap, totalRadNeed,
totalBeacon,
// Leasing
thermalTransfers, totalLeased, hotNodes, coldNodes,
// Workload
workloadMigrations,
// Resilience
damagedNodes, effectiveCapacity, totalDamage,
// Mesh
numBaselines, angularRes_arcsec, rangingPrecision_mm,
// Link
freeSpaceLoss_dB, linkBitrate, frameRate,
// Economy
swarmMarginAvg, swarmMarginMin, swarmMarginMax, headroom,
excessCooling_W, hourlyRevenue,
// 10MW
swarms_for_10MW, total_10MW_nodes, total_10MW_area, total_10MW_baselines,
};
}

function q_rad_helper(p) {
return p.emissivity * σ * (Math.pow(p.radTemp_K, 4) - Math.pow(p.sinkTemp_K, 4));
}

// ═══════════════════════════════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════════════════════════════
const fmt = (n, d = 1) => {
if (!isFinite(n)) return “∞”;
const a = Math.abs(n);
if (a >= 1e6) return (n / 1e6).toFixed(d) + “M”;
if (a >= 1e3) return (n / 1e3).toFixed(d) + “k”;
return n.toFixed(d);
};
const fW = w => {
if (Math.abs(w) >= 1e6) return (w / 1e6).toFixed(1) + “ MW”;
if (Math.abs(w) >= 1e3) return (w / 1e3).toFixed(1) + “ kW”;
if (Math.abs(w) >= 1) return w.toFixed(1) + “ W”;
return (w * 1000).toFixed(0) + “ mW”;
};
const pct = v => (v * 100).toFixed(1) + “%”;

function Sl({ k, label, unit, min, max, step, value, onChange, accent = “#00ccaa” }) {
return (
<div style={{ marginBottom: 7 }}>
<div style={{ display: “flex”, justifyContent: “space-between”, marginBottom: 1 }}>
<span style={{ fontSize: 9, color: “#5a7a8a” }}>{label}</span>
<span style={{ fontSize: 9, color: accent, fontWeight: 600 }}>
{Number.isInteger(step) && step >= 1 ? value : value.toFixed(2)}{unit ? ` ${unit}` : “”}
</span>
</div>
<input type=“range” min={min} max={max} step={step} value={value}
onChange={e => onChange(k, parseFloat(e.target.value))}
style={{ width: “100%”, height: 18, accentColor: accent, cursor: “pointer” }} />
</div>
);
}

// ═══════════════════════════════════════════════════════════════
// NODE VISUALIZATION — formation view
// ═══════════════════════════════════════════════════════════════
function FormationView({ swarm, nodeStates, onToggleDamage }) {
const N = swarm.N;
const W = 320, H = 280;
const cx = W / 2, cy = H / 2, R = 100;

// Node positions in circle
const positions = [];
for (let i = 0; i < N; i++) {
const angle = (i / N) * 2 * Math.PI - Math.PI / 2;
positions.push({ x: cx + R * Math.cos(angle), y: cy + R * Math.sin(angle) });
}

return (
<svg viewBox={`0 0 ${W} ${H}`} style={{ width: “100%”, maxWidth: 340, height: “auto” }}>
{/* Transfer lines */}
{swarm.thermalTransfers.map((t, i) => (
<line key={“t” + i}
x1={positions[t.from].x} y1={positions[t.from].y}
x2={positions[t.to].x} y2={positions[t.to].y}
stroke=”#ff884488” strokeWidth={Math.max(1, t.power / 20)}
strokeDasharray=“4,3” />
))}

```
  {/* Workload migration lines */}
  {swarm.workloadMigrations.map((m, i) => (
    <line key={"m" + i}
      x1={positions[m.from].x} y1={positions[m.from].y}
      x2={positions[m.to].x} y2={positions[m.to].y}
      stroke="#4488ff44" strokeWidth={2} strokeDasharray="2,4" />
  ))}

  {/* IR mesh baselines (faint) */}
  {positions.map((p1, i) =>
    positions.slice(i + 1).map((p2, j) => (
      <line key={`b${i}-${i + j + 1}`}
        x1={p1.x} y1={p1.y} x2={p2.x} y2={p2.y}
        stroke="#00ccaa08" strokeWidth={0.5} />
    ))
  )}

  {/* Nodes */}
  {swarm.nodes.map((node, i) => {
    const p = positions[i];
    const margin = node.thermalMargin;
    const damaged = nodeStates[i].damage > 0;
    const color = margin < 0 ? "#ff4444" : margin < 0.1 ? "#ffaa44" : margin < 0.3 ? "#00ccaa" : "#00ffaa";
    const r = 16 + (node.workloadFrac * 8);
    return (
      <g key={i} onClick={() => onToggleDamage(i)} style={{ cursor: "pointer" }}>
        {/* Radiator halo */}
        <circle cx={p.x} cy={p.y} r={r + 6} fill={color} opacity={0.08} />
        {/* Node body */}
        <circle cx={p.x} cy={p.y} r={r}
          fill="#0d1520" stroke={color} strokeWidth={damaged ? 1 : 2}
          strokeDasharray={damaged ? "3,3" : "none"} />
        {/* Margin indicator */}
        <circle cx={p.x} cy={p.y} r={r * Math.max(0, margin)}
          fill={color} opacity={0.2} />
        {/* Label */}
        <text x={p.x} y={p.y - 3} textAnchor="middle" fill={color} fontSize={9} fontWeight={700}
          fontFamily="monospace">N{i}</text>
        <text x={p.x} y={p.y + 7} textAnchor="middle" fill="#4a6a7a" fontSize={7}
          fontFamily="monospace">{pct(margin)}</text>
        {/* Damage X */}
        {damaged && <>
          <line x1={p.x - 5} y1={p.y - 12} x2={p.x + 5} y2={p.y - 6} stroke="#ff4444" strokeWidth={2} />
          <line x1={p.x + 5} y1={p.y - 12} x2={p.x - 5} y2={p.y - 6} stroke="#ff4444" strokeWidth={2} />
        </>}
      </g>
    );
  })}

  {/* Legend */}
  <text x={10} y={H - 8} fill="#3a5a6a" fontSize={7} fontFamily="monospace">
    Tap node to damage/repair · Orange=thermal transfer · Blue=workload migration
  </text>
</svg>
```

);
}

