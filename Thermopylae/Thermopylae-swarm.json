setNodeStates(prev => {
const next = […prev];
next[i] = { …next[i], damage: next[i].damage > 0 ? 0 : 0.5 };
return next;
});
}, []);

const setNodeWorkload = useCallback((i, wl) => {
setNodeStates(prev => {
const next = […prev];
next[i] = { …next[i], workload: wl };
return next;
});
