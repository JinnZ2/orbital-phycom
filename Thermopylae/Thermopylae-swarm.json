        { l: "Thermal transfers active", v: swarm.thermalTransfers.length + " links, " + fW(swarm.totalLeased), c: "#ffaa44" },
        { l: "Workload migrations", v: swarm.workloadMigrations.length + " active", c: "#4488ff" },
        { l: "Swarm beacon total", v: fW(swarm.totalBeacon), c: "#00ccaa" },
      ].map(({ l, v, c }) => (
        <div key={l} style={{ display: "flex", justifyContent: "space-between", fontSize: 9, padding: "3px 0", borderBottom: "1px solid #0a0e14" }}>
          <span style={{ color: "#5a7a8a" }}>{l}</span>
          <span style={{ color: c, fontWeight: 600 }}>{v}</span>
        </div>
      ))}
    </div>

    {/* Swarm roles */}
    <div style={{ background: "#0d1520", border: "1px solid #1a2a3a", borderRadius: 4, padding: "8px 10px", marginBottom: 10 }}>
      <div style={{ fontSize: 10, color: "#ffaa44", fontWeight: 700, marginBottom: 6 }}>ASSET CLASSES</div>
      {[
        { name: "Compute (exciter)", desc: "Makes heat. Jobs flow to cold nodes.", icon: "⚡", v: fW(swarm.totalCompute), c: "#4488ff" },
        { name: "Radiators (farms)", desc: "Headroom = wealth. Excess capacity is revenue.", icon: "▦", v: fmt(params.tilesPerNode * params.tileArea_m2 * params.numNodes, 0) + " m²", c: "#00ccaa" },
        { name: "Gates (bonds)", desc: "Thermal + info flow. 16-bit frames at " + params.gateBitrate_bps + " bps.", icon: "⇌", v: fW(swarm.totalBeacon), c: "#ffaa44" },
        { name: "Ground (consumers)", desc: "Beam power for cooling slots. Bilateral trades.", icon: "⬇", v: "$" + swarm.hourlyRevenue.toFixed(2) + "/hr", c: "#8866cc" },
      ].map(({ name, desc, icon, v, c }, i) => (
        <div key={i} style={{ display: "flex", gap: 8, marginBottom: 8 }}>
          <div style={{ width: 24, height: 24, borderRadius: 3, background: `${c}15`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 13, flexShrink: 0 }}>{icon}</div>
          <div style={{ flex: 1 }}>
            <div style={{ display: "flex", justifyContent: "space-between" }}>
              <span style={{ fontSize: 10, color: c, fontWeight: 600 }}>{name}</span>
              <span style={{ fontSize: 9, color: "#4a6a7a" }}>{v}</span>
            </div>
            <div style={{ fontSize: 8, color: "#3a4a5a", lineHeight: 1.4 }}>{desc}</div>
          </div>
        </div>
      ))}
    </div>

    {/* 10MW projection */}
    <div style={{ background: "#00ccaa06", border: "1px solid #00ccaa15", borderRadius: 4, padding: "8px 10px", fontSize: 9, color: "#5a8a7a", lineHeight: 1.6 }}>
      <b style={{ color: "#00ccaa" }}>10 MW PROJECTION: </b>
      {swarm.swarms_for_10MW} swarms × {params.numNodes} nodes = {swarm.total_10MW_nodes} platforms.
      ~{(swarm.total_10MW_nodes * params.tilesPerNode * params.tileArea_m2 / 1000).toFixed(0)}k m² total radiator.
      {swarm.total_10MW_baselines.toLocaleString()} IR baselines.
      Mass scales linearly. Utility compounds: each new swarm adds to the thermal market and the ranging mesh.
      Federation via lunar relay keeps swarms decoupled at orbital-mechanic scale.
    </div>
  </>}

  {/* ━━━ IR MESH ━━━ */}
  {tab === "mesh" && <>
    <div style={{ background: "#0d1520", border: "1px solid #00ccaa25", borderRadius: 4, padding: "8px 10px", marginBottom: 10 }}>
      <div style={{ fontSize: 10, color: "#00ccaa", fontWeight: 700, marginBottom: 8 }}>DISTRIBUTED IR INTERFEROMETER</div>

      {[
        { l: "Nodes", v: params.numNodes.toString(), c: "#00ccaa" },
        { l: "Baselines", v: swarm.numBaselines.toString(), c: "#4488ff" },
        { l: "Max baseline", v: (params.formationSpacing_m * 1.5).toFixed(0) + " m", c: "#ffaa44" },
        { l: "Angular resolution", v: swarm.angularRes_arcsec.toFixed(4) + "″", c: "#00ffaa" },
        { l: "Ranging precision", v: swarm.rangingPrecision_mm.toFixed(2) + " mm", c: "#00ffaa" },
        { l: "Free space loss", v: swarm.freeSpaceLoss_dB.toFixed(1) + " dB", c: "#ff8844" },
      ].map(({ l, v, c }) => (
        <div key={l} style={{ display: "flex", justifyContent: "space-between", fontSize: 10, padding: "3px 0", borderBottom: "1px solid #0a0e14" }}>
          <span style={{ color: "#5a7a8a" }}>{l}</span>
          <span style={{ color: c, fontWeight: 600 }}>{v}</span>
        </div>
      ))}
    </div>

    {/* Gate frame format */}
    <div style={{ background: "#0d1520", border: "1px solid #ffaa4425", borderRadius: 4, padding: "8px 10px", marginBottom: 10 }}>
      <div style={{ fontSize: 10, color: "#ffaa44", fontWeight: 700, marginBottom: 6 }}>GATE FRAME FORMAT</div>
      <div style={{ display: "flex", gap: 2, marginBottom: 6 }}>
        <div style={{ flex: 1, background: "#4488ff20", border: "1px solid #4488ff40", borderRadius: 2, padding: "4px", textAlign: "center" }}>
          <div style={{ fontSize: 7, color: "#4488ff" }}>NODE ID</div>
          <div style={{ fontSize: 11, color: "#4488ff", fontWeight: 700 }}>8 bit</div>
        </div>
        <div style={{ flex: 1, background: "#00ccaa20", border: "1px solid #00ccaa40", borderRadius: 2, padding: "4px", textAlign: "center" }}>
          <div style={{ fontSize: 7, color: "#00ccaa" }}>MARGIN</div>
          <div style={{ fontSize: 11, color: "#00ccaa", fontWeight: 700 }}>8 bit</div>
        </div>
      </div>
      <div style={{ fontSize: 9, color: "#4a6a7a", lineHeight: 1.5 }}>
        16 bits/frame × {swarm.frameRate.toFixed(1)} frames/sec = {params.gateBitrate_bps} bps per gate.
        OOK modulation via 1% duty cycle PCM thermal pulse.
        Each node broadcasts: "I am N{"{x}"}, I have {"{y}"}% margin."
        10⁴ photons/bit at {params.formationSpacing_m}m = error-free link.
      </div>
    </div>

    {/* Formation spacing slider */}
    <Sl k="formationSpacing_m" label="Formation Spacing" unit="m" min={50} max={1000} step={10}
      value={params.formationSpacing_m} onChange={setP} accent="#00ccaa" />
    <Sl k="gateBitrate_bps" label="Gate Bitrate" unit="bps" min={10} max={1000} step={10}
      value={params.gateBitrate_bps} onChange={setP} accent="#ffaa44" />

    <div style={{
      background: "#00ccaa06", border: "1px solid #00ccaa15", borderRadius: 4,
      padding: "8px 10px", fontSize: 9, color: "#5a8a7a", lineHeight: 1.6, marginTop: 6,
    }}>
      <b style={{ color: "#00ccaa" }}>NO RF REQUIRED: </b>
      Formation control via mutual IR ranging. Each gate is both a beacon and a rangefinder.
      cm-level precision from waste-heat photons. The thermal exhaust IS the navigation system.
    </div>
  </>}

  {/* ━━━ CONFIG ━━━ */}
  {tab === "config" && <>
    {[
      { title: "SWARM", color: "#ffffff", ps: [
        { key: "numNodes", label: "Nodes", unit: "", min: 2, max: 20, step: 1 },
        { key: "nodePower_kW", label: "Power/Node", unit: "kW", min: 10, max: 500, step: 10 },
        { key: "computeEff", label: "Compute Eff", unit: "", min: 0.05, max: 0.5, step: 0.01 },
        { key: "formationSpacing_m", label: "Spacing", unit: "m", min: 50, max: 1000, step: 10 },
      ]},
      { title: "NODE THERMAL", color: "#ff8844", ps: [
        { key: "eclipseHeater_W", label: "Eclipse Heater", unit: "W", min: 100, max: 2000, step: 50 },
        { key: "propHeating_W", label: "Prop Heating", unit: "W", min: 500, max: 5000, step: 100 },
        { key: "tpvInput_W", label: "TPV Input", unit: "W", min: 1000, max: 15000, step: 500 },
        { key: "tpvEff", label: "TPV Efficiency", unit: "", min: 0.05, max: 0.35, step: 0.01 },
      ]},
      { title: "RADIATOR", color: "#00ccaa", ps: [
        { key: "tilesPerNode", label: "Tiles/Node", unit: "", min: 4, max: 40, step: 1 },
        { key: "tileArea_m2", label: "Tile Area", unit: "m²", min: 5, max: 50, step: 1 },
        { key: "radTemp_K", label: "Rad Temp", unit: "K", min: 250, max: 500, step: 5 },
        { key: "emissivity", label: "Emissivity", unit: "", min: 0.5, max: 0.98, step: 0.01 },
        { key: "hotGateFrac", label: "Hot Gate Frac", unit: "", min: 0.01, max: 0.3, step: 0.01 },
      ]},
      { title: "SWARM LINKS", color: "#4488ff", ps: [
        { key: "maxIRTransfer_W", label: "Max IR Transfer", unit: "W", min: 5, max: 200, step: 5 },
        { key: "gateBitrate_bps", label: "Gate Bitrate", unit: "bps", min: 10, max: 1000, step: 10 },
      ]},
    ].map(({ title, color, ps }) => (
      <div key={title} style={{ marginBottom: 10 }}>
        <div style={{ fontSize: 9, color, fontWeight: 700, letterSpacing: 0.5, marginBottom: 5 }}>{title}</div>
        {ps.map(p => <Sl key={p.key} {...p} value={params[p.key]} onChange={setP} accent={color} />)}
      </div>
    ))}
  </>}

  <div style={{ fontSize: 7, color: "#1a2a3a", textAlign: "center", padding: 10 }}>
    Thermopylae Swarm · Thermal Economy · Distributed IR Mesh
  </div>
</div>
```

);
}
