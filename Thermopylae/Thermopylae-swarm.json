tpvInput_W: 5000, tpvEff: 0.15,
attitudeLouver_W: 200,
// Radiator
tilesPerNode: 20, tileArea_m2: 25,
radTemp_K: 335, emissivity: 0.92, sinkTemp_K: 3,
radDensity_kgm2: 5,
// Hot gates
hotGateFrac: 0.10, beaconModEff: 0.02,
// Swarm
formationSpacing_m: 300,
maxIRTransfer_W: 50,
gateBitrate_bps: 100,
};

