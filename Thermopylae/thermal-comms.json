    <MiniChart data={thermalSweep} xKey="x" yKey="costPerPFLOPS"
      xLabel={sweepDef.label} yLabel="$/PFLOPS" color="#ff6644" highlight={tParams[sweepParam]} />

    {/* Sliders */}
    <div style={{ marginTop: 12 }}>
      <div style={{ ...S.label, marginBottom: 8 }}>PARAMETERS</div>
      {THERMAL_PARAMS.map(({ key, label, unit, min, max, step }) => (
