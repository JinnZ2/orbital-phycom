            <span style={{ fontSize: 10, color: "#5a7a8a" }}>{label}</span>
            <span style={{ fontSize: 10, color: "#00ccaa", fontWeight: 600 }}>{tParams[key]}{unit ? ` ${unit}` : ""}</span>
          </div>
          <input type="range" min={min} max={max} step={step} value={tParams[key]}
            onChange={e => setTP(key, parseFloat(e.target.value))} style={S.slider} />
        </div>
      ))}
    </div>
  </>}

  {/* ═══════════ COMMS TAB ═══════════ */}
  {tab === "comms" && <>
    {/* Comms presets */}
    <div style={{ display: "flex", flexWrap: "wrap", gap: 5, marginBottom: 12 }}>
      {Object.keys(COMMS_PRESETS).map(name => (
        <button key={name} onClick={() => { setCParams(COMMS_PRESETS[name]); setActiveCommsPreset(name); }}
          style={{
            background: activeCommsPreset === name ? "#4488ff15" : "#0d1520",
            border: `1px solid ${activeCommsPreset === name ? "#4488ff" : "#1a2a3a"}`,
            color: activeCommsPreset === name ? "#4488ff" : "#5a7a8a",
            borderRadius: 4, padding: "4px 7px", fontSize: 10, cursor: "pointer", fontFamily: "inherit",
          }}>{name}</button>
      ))}
    </div>

    {/* Comms status */}
    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 6, marginBottom: 12 }}>
      {[
        { l: "λ peak", v: comms.lambda_peak_um.toFixed(1) + " μm", s: fmt(comms.freq_peak) + " Hz" },
        { l: "Beam Div", v: comms.beamDivergence_arcsec.toFixed(2) + "\"", s: fmt(comms.A_eff, 0) + " m² eff" },
        { l: "Rx Power", v: fmt(comms.receivedPower_W) + "W", s: "SNR " + comms.SNR_dB.toFixed(1) + " dB" },
        { l: "Capacity", v: fmtBits(comms.channelCapacity_bps), s: "Shannon limit" },
      ].map(({ l, v, s }) => (
        <div key={l} style={S.box}>
          <div style={{ ...S.label, color: "#2a5a8a" }}>{l}</div>
          <div style={{ ...S.val, color: "#88ccff" }}>{v}</div>
          <div style={S.sub}>{s}</div>
        </div>
      ))}
    </div>

    {/* Link budget */}
    <div style={{ ...S.box, marginBottom: 12 }}>
      <div style={{ ...S.label, color: "#2a5a8a", marginBottom: 6 }}>LINK BUDGET</div>
      {[
        { l: "Directed Power", v: fmt(comms.directedPower_W) + "W" },
        { l: "Capture Frac", v: (comms.capturedFraction * 100).toFixed(4) + "%" },
        { l: "Rx Power", v: fmt(comms.receivedPower_W) + "W" },
        { l: "Noise Floor", v: fmt(comms.noisePower_W) + "W" },
        { l: "SNR", v: comms.SNR_dB.toFixed(1) + " dB" },
      ].map(({ l, v }) => (
        <div key={l} style={{ display: "flex", justifyContent: "space-between", fontSize: 10, padding: "2px 0", borderBottom: "1px solid #0a0e14" }}>
          <span style={{ color: "#4a6a7a" }}>{l}</span>
          <span style={{ color: "#88ccff", fontWeight: 600 }}>{v}</span>
        </div>
      ))}
    </div>

    {/* Sweep */}
    <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 6 }}>
      <span style={{ ...S.label, color: "#2a5a8a" }}>SWEEP:</span>
      <select value={commsSweep} onChange={e => setCommsSweep(e.target.value)}
        style={{ background: "#0d1520", border: "1px solid #1a2a3a", color: "#4488ff", borderRadius: 4, padding: "3px 6px", fontSize: 10, fontFamily: "inherit" }}>
        {COMMS_PARAMS.map(p => <option key={p.key} value={p.key}>{p.label}</option>)}
      </select>
    </div>
    <MiniChart data={commsSweepData} xKey="x" yKey="channelCapacity_bps"
      xLabel={commsSweepDef.label} yLabel="Capacity bps" color="#4488ff" highlight={cParams[commsSweep]} logY />
    <MiniChart data={commsSweepData} xKey="x" yKey="SNR_dB"
      xLabel={commsSweepDef.label} yLabel="SNR dB" color="#ffaa44" highlight={cParams[commsSweep]} />

    {/* Sliders */}
    <div style={{ marginTop: 12 }}>
      <div style={{ ...S.label, color: "#2a5a8a", marginBottom: 8 }}>LINK PARAMETERS</div>
      {COMMS_PARAMS.map(({ key, label, unit, min, max, step }) => (
        <div key={key} style={{ marginBottom: 10 }}>
          <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 2 }}>
            <span style={{ fontSize: 10, color: "#5a7a8a" }}>{label}</span>
            <span style={{ fontSize: 10, color: "#4488ff", fontWeight: 600 }}>{cParams[key]}{unit ? ` ${unit}` : ""}</span>
          </div>
          <input type="range" min={min} max={max} step={step} value={cParams[key]}
            onChange={e => setCP(key, parseFloat(e.target.value))} style={{ ...S.slider, accentColor: "#4488ff" }} />
        </div>
      ))}
    </div>
  </>}

  {/* ═══════════ DUAL-USE TAB ═══════════ */}
  {tab === "compare" && <>
    <div style={{ ...S.box, marginBottom: 12, borderColor: "#00ccaa40" }}>
      <div style={{ ...S.label, color: "#00ccaa", marginBottom: 8 }}>
        DUAL-USE vs DEDICATED X-BAND
      </div>

      <CompBar label1="Thermal IR" val1={comms.channelCapacity_bps}
        label2="X-Band 3m" val2={comms.xband_capacity_bps}
        color1="#00ccaa" color2="#ff6644"
        unit={fmtBits} />

      <CompBar label1="IR SNR" val1={comms.SNR_dB}
        label2="X-Band SNR" val2={comms.xband_SNR_dB}
        color1="#00ccaa" color2="#ff6644"
        unit={v => v.toFixed(1) + " dB"} />

      <CompBar label1="IR overhead" val1={comms.dualUseMassOverhead}
        label2="X-Band mass" val2={comms.xband_mass_kg}
        color1="#00ccaa" color2="#ff6644"
        unit={v => v.toFixed(0) + " kg"} />
    </div>

    {/* Verdict */}
    <div style={{ ...S.box, marginBottom: 12 }}>
      <div style={{ ...S.label, marginBottom: 6 }}>MASS EFFICIENCY</div>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline" }}>
        <div>
          <div style={{ fontSize: 9, color: "#4a6a7a" }}>bps/kg (thermal IR)</div>
          <div style={{ fontSize: 16, color: "#00ccaa", fontWeight: 700 }}>
            {comms.dualUseMassOverhead > 0 ? fmtBits(comms.channelCapacity_bps / comms.dualUseMassOverhead) : "∞"}/kg
          </div>
        </div>
        <div style={{ textAlign: "right" }}>
          <div style={{ fontSize: 9, color: "#4a6a7a" }}>bps/kg (X-band)</div>
          <div style={{ fontSize: 16, color: "#ff6644", fontWeight: 700 }}>
            {fmtBits(comms.xband_capacity_bps / comms.xband_mass_kg)}/kg
          </div>
        </div>
      </div>
      <div style={{ marginTop: 8, fontSize: 10, color: comms.massEfficiencyRatio > 1 ? "#00ffaa" : "#ff6644", fontWeight: 600, textAlign: "center" }}>
        {comms.massEfficiencyRatio > 1
          ? `DUAL-USE WINS: ${comms.massEfficiencyRatio.toFixed(1)}× mass efficiency`
          : `X-BAND WINS: ${(1 / comms.massEfficiencyRatio).toFixed(1)}× mass efficiency`}
      </div>
    </div>

    {/* Mass budget breakdown */}
    <div style={{ ...S.box, marginBottom: 12 }}>
      <div style={{ ...S.label, marginBottom: 6 }}>MASS BUDGET</div>
      {[
        { l: "Radiator (already paid)", v: fmt(thermal.radiatorMass_kg, 0) + " kg", c: "#5a7a8a" },
        { l: "Metamaterial layer (+)", v: comms.dualUseMassOverhead.toFixed(0) + " kg", c: "#00ccaa" },
        { l: "X-Band system (avoided)", v: "-" + comms.xband_mass_kg + " kg", c: "#ff6644" },
        { l: "Net savings", v: comms.massSaved_kg.toFixed(0) + " kg", c: comms.massSaved_kg > 0 ? "#00ffaa" : "#ff4444" },
        { l: "Launch cost saved", v: fmtCost(comms.massSaved_kg * tParams.launchCost), c: comms.massSaved_kg > 0 ? "#00ffaa" : "#ff4444" },
      ].map(({ l, v, c }) => (
        <div key={l} style={{ display: "flex", justifyContent: "space-between", fontSize: 10, padding: "3px 0", borderBottom: "1px solid #0a0e14" }}>
          <span style={{ color: "#4a6a7a" }}>{l}</span>
          <span style={{ color: c, fontWeight: 600 }}>{v}</span>
        </div>
      ))}
    </div>

    {/* Where it works / doesn't */}
    <div style={{ ...S.box, marginBottom: 12, fontSize: 10, color: "#4a6a7a", lineHeight: 1.6 }}>
      <span style={{ color: "#00ccaa", fontWeight: 700 }}>WHERE IT WORKS: </span>
      Large radiator area (high compute), short-medium distances, cryogenic receiver.
      Beam fill factor is the critical unknown — metamaterial coherence determines
      whether this is a flashlight or a laser.
      <br /><br />
      <span style={{ color: "#ff6644", fontWeight: 700 }}>WHERE IT BREAKS: </span>
      Deep space (inverse square kills you), atmospheric absorption at mid-IR
      (need space-based receiver or select atmospheric windows), and any scenario
      where radiator temp modulation conflicts with thermal stability requirements.
    </div>

    {/* The key insight */}
    <div style={{
      background: "#00ccaa08", border: "1px solid #00ccaa30",
      borderRadius: 4, padding: "8px 10px", fontSize: 10, color: "#6a9a8a", lineHeight: 1.6,
    }}>
      <span style={{ color: "#00ccaa", fontWeight: 700 }}>CORE INSIGHT: </span>
      The radiator is a sunk-mass energy emitter. The only question is whether
      you can impose enough structure on the emission to carry information.
      At 1500m² you have aperture gain that no dedicated antenna can match at
      these wavelengths. The bottleneck is coherence — how much of that area
      acts as a phased array vs. a light bulb.
    </div>
  </>}

  <div style={{ fontSize: 8, color: "#1a2a3a", textAlign: "center", padding: 12 }}>
    Stefan-Boltzmann · Shannon-Hartley · Planck spectral radiance
  </div>
</div>
```

);
}
