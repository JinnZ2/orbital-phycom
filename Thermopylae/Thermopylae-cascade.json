import { useState, useMemo, useCallback } from “react”;

// ═══════════════════════════════════════════════════════════════
// CONSTANTS
// ═══════════════════════════════════════════════════════════════
const σ = 5.670374419e-8;
const k_B = 1.380649e-23;
const h_planck = 6.62607015e-34;
const c_light = 2.998e8;
const PI = Math.PI;

// ═══════════════════════════════════════════════════════════════
// CASCADE ENGINE
// Models 1 joule from input → final dump through 5 layers
// Each layer: takes power in, extracts value, passes remainder
// ═══════════════════════════════════════════════════════════════

function computeCascade(p) {
const P_input = p.computePower_kW * 1000; // W

// ── L1: COMPUTE ──────────────────────────────────────────
const P_compute = P_input * p.efficiency;
const FLOPS = P_compute * p.computeDensity_GFLOPSW * 1e9;
const P_waste_L1 = P_input - P_compute;
// Thermal path efficiency: how much waste heat reaches the loop vs lost in transit
const P_into_loop = P_waste_L1 * p.thermalPathEff;
const P_path_loss = P_waste_L1 - P_into_loop;

// ── L2: INTERNAL THERMAL WORK ────────────────────────────
// Fraction of loop heat tapped for survival/utility heating
const P_survival = P_into_loop * p.survivalTapFrac;
// Services: tank heating, battery conditioning, hinge warmth, sensor baselines
const survivalServices = [
{ name: “Tank/Prop Heating”, frac: 0.4 },
{ name: “Battery Conditioning”, frac: 0.25 },
{ name: “Mech/Hinge Warmth”, frac: 0.2 },
{ name: “Sensor Baselines”, frac: 0.15 },
].map(s => ({ …s, power: P_survival * s.frac }));
const P_after_L2 = P_into_loop - P_survival;

// ── L3: HIGH-VALUE CONVERSION ────────────────────────────
// TPV / thermoelectric / ORC from hottest loop segments
const T_hot_loop = p.hotLoopTemp_K;
const T_cold_sink = p.radTemp_K; // reject to radiator temp
const carnot_eff = 1 - (T_cold_sink / T_hot_loop);
const conversion_eff = carnot_eff * p.conversionFracOfCarnot;
const P_converted = P_after_L2 * p.conversionFrac * conversion_eff;
const P_conversion_waste = P_after_L2 * p.conversionFrac * (1 - conversion_eff);

// What the converted power feeds
const conversionServices = [
{ name: “Telemetry Beacon”, frac: 0.3 },
{ name: “Clock & Sync”, frac: 0.2 },
{ name: “Safety Logic”, frac: 0.25 },
{ name: “Fault Beacon”, frac: 0.25 },
].map(s => ({ …s, power: P_converted * s.frac }));

const P_after_L3 = P_after_L2 - (P_after_L2 * p.conversionFrac) + P_conversion_waste;

// ── L4: DIRECTIONAL EXPORT (Thermopylae) ─────────────────
const P_to_radiators = P_after_L3;

// Split: hot segment vs bulk
const P_hot_segment = P_to_radiators * p.hotSegmentFrac;
const P_bulk_rad = P_to_radiators - P_hot_segment;

// Hot segment properties
const T_emit = p.hotSegmentTemp_K;
const λ_emit = 2.898e-3 / T_emit;
const ν_emit = c_light / λ_emit;

// Spectral shaping: engineered emissivity
// ε_band = enhanced emissivity in comms band
// ε_suppress = reduced emissivity outside band
// Net effect: fraction of hot segment power in useful band
const spectralConcentration = p.spectralEfficiency; // fraction in-band

// Spatial: horn geometry
const q_hot = p.emissivity * σ * (Math.pow(T_emit, 4) - Math.pow(p.sinkTemp_K, 4));
const A_hot = q_hot > 0 ? P_hot_segment / q_hot : 0;
const A_per_horn = p.hornAperture_m * p.hornAperture_m;
const N_horns = Math.max(1, Math.floor(A_hot / A_per_horn));
const Ω_beam = λ_emit * λ_emit / A_per_horn;
const beamDiv_arcsec = Math.sqrt(Ω_beam) * 206265;

// Temporal: duty cycle pulsing
// During ON phase, effective temp is higher (stored thermal mass)
const T_pulse = T_emit * Math.pow(1 / p.dutyCycle, 0.25); // T⁴ scaling
const peakBrightnessFactor = Math.pow(T_pulse / T_emit, 4);

// Planck spectral radiance at emit frequency
const hv_kT = (h_planck * ν_emit) / (k_B * T_emit);
const B_ν = (2 * h_planck * Math.pow(ν_emit, 3) / (c_light * c_light)) / (Math.exp(hv_kT) - 1);

// Power in directed beam (all horns, in-band, duty-cycle averaged)
const Δν = p.modBW_GHz * 1e9;
const P_per_mode = B_ν * Δν * λ_emit * λ_emit;
const P_directed = N_horns * P_per_mode * spectralConcentration;
const P_directed_pulsed = P_directed * peakBrightnessFactor * p.dutyCycle; // average

// Link budget
const d_m = p.distance_km * 1000;
const spotArea = Ω_beam * d_m * d_m;
const captureFrac = Math.min(1, p.rxArea_m2 / spotArea);
const P_rx = P_directed_pulsed * captureFrac;
const N_noise = k_B * p.rxTemp_K * Δν;
const SNR = P_rx / N_noise;
const SNR_dB = 10 * Math.log10(Math.max(SNR, 1e-30));
const switchRate = p.switchRate_kHz * 1000;
const capacity_bps = switchRate * Math.log2(1 + Math.max(SNR, 0));

// Directional export services
const dirServices = [
{ name: “Comms/Telemetry”, frac: 0.5, power: P_directed_pulsed * 0.5 },
{ name: “Navigation Beacon”, frac: 0.2, power: P_directed_pulsed * 0.2 },
{ name: “Ranging/Sync”, frac: 0.15, power: P_directed_pulsed * 0.15 },
{ name: “Attitude Bias”, frac: 0.15, power: P_directed_pulsed * 0.15 },
];

// ── L5: FINAL DUMP ───────────────────────────────────────
const P_final_dump = P_bulk_rad + (P_hot_segment - P_directed_pulsed);
const q_bulk = p.emissivity * σ * (Math.pow(p.radTemp_K, 4) - Math.pow(p.sinkTemp_K, 4));
const A_bulk = q_bulk > 0 ? P_final_dump / q_bulk : Infinity;
const A_total = A_bulk + A_hot;
const mass_radiator = A_total * p.radDensity_kgm2;

// Final dump shaping
const dumpServices = [
{ name: “Neighbor Avoidance”, desc: “Shaped to avoid heating adjacent craft” },
{ name: “Sensor Background”, desc: “Known emission for own sensor calibration” },
{ name: “Health Telemetry”, desc: “Flow patterns encode system state” },
];

// ── SUMMARY ──────────────────────────────────────────────
// Total value extracted before final dump
const P_total_extracted = P_compute + P_survival + P_converted + P_directed_pulsed;
const extraction_ratio = P_total_extracted / P_input;

// Gradient utilization: how many services ride each drop
const gradientCount = survivalServices.length + conversionServices.length + dirServices.length + dumpServices.length;

return {
P_input, P_compute, FLOPS, P_waste_L1, P_into_loop, P_path_loss,
// L2
P_survival, survivalServices, P_after_L2,
// L3
T_hot_loop, carnot_eff, conversion_eff, P_converted, P_conversion_waste,
conversionServices, P_after_L3,
// L4
P_to_radiators, P_hot_segment, P_bulk_rad,
T_emit, λ_emit: λ_emit * 1e6, ν_emit, spectralConcentration,
A_hot, N_horns, Ω_beam, beamDiv_arcsec,
T_pulse, peakBrightnessFactor, P_directed: P_directed_pulsed,
P_rx, SNR, SNR_dB, capacity_bps,
dirServices,
// L5
P_final_dump, A_bulk, A_total, mass_radiator, dumpServices,
// Summary
P_total_extracted, extraction_ratio, gradientCount,
dutyCycle: p.dutyCycle,
};
}

// ═══════════════════════════════════════════════════════════════
// UI
// ═══════════════════════════════════════════════════════════════
const fmt = (n, d = 1) => {
if (!isFinite(n)) return “∞”;
const a = Math.abs(n);
if (a >= 1e15) return (n / 1e15).toFixed(d) + “P”;
if (a >= 1e12) return (n / 1e12).toFixed(d) + “T”;
if (a >= 1e9) return (n / 1e9).toFixed(d) + “G”;
if (a >= 1e6) return (n / 1e6).toFixed(d) + “M”;
if (a >= 1e3) return (n / 1e3).toFixed(d) + “k”;
return n.toFixed(d);
};
const fmtB = b => {
if (!isFinite(b) || b <= 0) return “0 bps”;
if (b >= 1e9) return (b / 1e9).toFixed(1) + “ Gbps”;
if (b >= 1e6) return (b / 1e6).toFixed(1) + “ Mbps”;
if (b >= 1e3) return (b / 1e3).toFixed(1) + “ kbps”;
return b.toFixed(0) + “ bps”;
};
const pct = (v) => (v * 100).toFixed(1) + “%”;

function Sl({ k, label, unit, min, max, step, value, onChange, accent = “#00ccaa” }) {
return (
<div style={{ marginBottom: 8 }}>
<div style={{ display: “flex”, justifyContent: “space-between”, marginBottom: 1 }}>
<span style={{ fontSize: 9, color: “#5a7a8a” }}>{label}</span>
<span style={{ fontSize: 9, color: accent, fontWeight: 600 }}>{value}{unit ? ` ${unit}` : “”}</span>
</div>
<input type=“range” min={min} max={max} step={step} value={value}
onChange={e => onChange(k, parseFloat(e.target.value))}
style={{ width: “100%”, height: 18, accentColor: accent, cursor: “pointer” }} />
</div>
);
}

// Cascade flow bar
function FlowBar({ layers }) {
const total = layers[0]?.power || 1;
return (
<div style={{ marginBottom: 12 }}>
{/* Stacked horizontal bar */}
<div style={{ display: “flex”, height: 24, borderRadius: 4, overflow: “hidden”, marginBottom: 4 }}>
{layers.map((l, i) => {
const w = Math.max(0.5, (l.power / total) * 100);
return (
<div key={i} style={{
width: `${w}%`, background: l.color, minWidth: 1,
display: “flex”, alignItems: “center”, justifyContent: “center”,
transition: “width 0.3s”,
}}>
{w > 8 && <span style={{ fontSize: 7, color: “#0a0e14”, fontWeight: 700 }}>{l.label}</span>}
</div>
);
})}
</div>
{/* Legend */}
<div style={{ display: “flex”, flexWrap: “wrap”, gap: 6 }}>
{layers.map((l, i) => (
<div key={i} style={{ display: “flex”, alignItems: “center”, gap: 3 }}>
<div style={{ width: 6, height: 6, borderRadius: 1, background: l.color }} />
<span style={{ fontSize: 8, color: “#4a6a7a” }}>{l.label}: {fmt(l.power)}W ({pct(l.power / total)})</span>
</div>
))}
</div>
</div>
);
}

// Layer detail card
function LayerCard({ color, number, title, children }) {
return (
<div style={{
background: “#0d1520”, border: `1px solid ${color}30`,
borderRadius: 4, padding: “8px 10px”, marginBottom: 8,
}}>
<div style={{ display: “flex”, alignItems: “center”, gap: 6, marginBottom: 6 }}>
<div style={{
width: 18, height: 18, borderRadius: 3, background: `${color}20`,
display: “flex”, alignItems: “center”, justifyContent: “center”,
fontSize: 10, color, fontWeight: 700,
}}>L{number}</div>
<span style={{ fontSize: 10, color, fontWeight: 600, letterSpacing: 0.5 }}>{title}</span>
</div>
{children}
</div>
);
}

function ServiceList({ services, color }) {
return (
<div style={{ marginTop: 4 }}>
{services.map((s, i) => (
<div key={i} style={{ display: “flex”, justifyContent: “space-between”, fontSize: 9, padding: “2px 0”, borderBottom: “1px solid #0a0e1499” }}>
<span style={{ color: “#5a7a8a” }}>{s.name}</span>
<span style={{ color, fontWeight: 600 }}>{fmt(s.power)}W</span>
</div>
))}
</div>
);
}

