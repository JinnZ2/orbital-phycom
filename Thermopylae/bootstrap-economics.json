    {/* Revenue breakdown */}
    {latest && (
      <div style={{ background: "#0d1520", border: "1px solid #1a2a3a", borderRadius: 4, padding: "8px 10px", marginTop: 6 }}>
        <div style={{ fontSize: 9, color: "#ffcc00", fontWeight: 700, marginBottom: 6 }}>REVENUE SOURCES (@ month {latest.month})</div>
        {[
          { l: "Compute nodes", v: latest.nodes_compute, rev: latest.nodes_compute * NODE_TYPES.compute.rev_month, c: "#4488ff" },
          { l: "Radiator nodes", v: latest.nodes_radiator, rev: latest.nodes_radiator * NODE_TYPES.radiator.rev_month, c: "#00ccaa" },
          { l: "Seed factories", v: latest.nodes_seed, rev: latest.nodes_seed * NODE_TYPES.seed.rev_month, c: "#ffcc00" },
          { l: "Debris cleanup", v: fmt(latest.total_captured_tons, 0) + "t", rev: latest.total_captured_tons * params.debrisCredit_per_ton * 0.01, c: "#ff8844" },
        ].map(({ l, v, rev, c }) => (
          <div key={l} style={{ display: "flex", justifyContent: "space-between", fontSize: 9, padding: "3px 0", borderBottom: "1px solid #0a0e14" }}>
            <span style={{ color: "#5a7a8a" }}>{l} ({v})</span>
            <span style={{ color: c, fontWeight: 600 }}>{f$(rev)}/mo</span>
          </div>
        ))}
        <div style={{ display: "flex", justifyContent: "space-between", fontSize: 10, padding: "4px 0", marginTop: 2 }}>
          <span style={{ color: "#ffffff", fontWeight: 700 }}>Total</span>
          <span style={{ color: "#00ffaa", fontWeight: 700 }}>{f$(latest.monthRevenue)}/mo</span>
        </div>
      </div>
    )}

    {/* Key metrics */}
    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 4, marginTop: 8 }}>
      {[
        { l: "Seed Investment", v: f$(params.seedCost), c: "#ff4444" },
        { l: "Total Invested", v: f$(latest?.totalCost || 0), c: "#ff6644" },
        { l: "Total Revenue", v: f$(latest?.cumRevenue || 0), c: "#00ffaa" },
        { l: "ROI", v: (latest?.roi_pct || 0).toFixed(0) + "%", c: latest?.roi_pct > 0 ? "#00ffaa" : "#ff4444" },
      ].map(({ l, v, c }) => (
        <div key={l} style={{ background: "#0d1520", border: `1px solid ${c}20`, borderRadius: 4, padding: "5px 8px" }}>
          <div style={{ fontSize: 8, color: "#3a5a6a" }}>{l}</div>
          <div style={{ fontSize: 14, color: c, fontWeight: 700 }}>{v}</div>
        </div>
      ))}
    </div>
  </>}

  {/* ━━━ CONFIG ━━━ */}
  {tab === "config" && <>
    {[
      { title: "INVESTMENT", color: "#ff6644", ps: [
        { key: "seedCost", label: "Seed Launch Cost", unit: "$", min: 500000, max: 50000000, step: 500000 },
        { key: "monthlyOps", label: "Monthly Ops Cost", unit: "$/mo", min: 10000, max: 500000, step: 10000 },
      ]},
      { title: "REVENUE", color: "#00ffaa", ps: [
        { key: "debrisCredit_per_ton", label: "Debris Credit", unit: "$/ton", min: 100000, max: 5000000, step: 100000 },
      ]},
      { title: "OPERATIONS", color: "#ffaa44", ps: [
        { key: "dutyFraction", label: "Duty Fraction", unit: "", min: 0.1, max: 0.9, step: 0.05 },
        { key: "targetTorchCount", label: "Target Torch Fleet", unit: "", min: 2, max: 20, step: 1 },
        { key: "upgradeYieldThreshold", label: "Upgrade Threshold", unit: "", min: 0.6, max: 0.95, step: 0.05 },
      ]},
      { title: "SIMULATION", color: "#4488ff", ps: [
        { key: "simMonths", label: "Months to Simulate", unit: "mo", min: 6, max: 60, step: 1 },
      ]},
    ].map(({ title, color, ps }) => (
      <div key={title} style={{ marginBottom: 10 }}>
        <div style={{ fontSize: 9, color, fontWeight: 700, letterSpacing: 0.5, marginBottom: 5 }}>{title}</div>
        {ps.map(p => <Sl key={p.key} {...p} value={params[p.key]} onChange={setP} accent={color} />)}
      </div>
    ))}

    <div style={{
      background: "#00ccaa06", border: "1px solid #00ccaa15", borderRadius: 4,
      padding: "8px 10px", fontSize: 9, color: "#5a8a7a", lineHeight: 1.6,
    }}>
      <b style={{ color: "#00ccaa" }}>MODEL ASSUMPTIONS: </b>
      Gen 1 print success rate 50% (5 nozzles → 1 good). Gen 2: 70%. Gen 3: 90%.
      Failed prints recover 60% material. Nodes revenue: compute $15k/mo, radiator $5k/mo,
      seed $1k/mo. Debris credits at 1% monthly realization rate.
      Torch nozzle death recycles 60% of torch mass back to stockpile.
    </div>
  </>}

  <div style={{ fontSize: 7, color: "#1a2a3a", textAlign: "center", padding: 10 }}>
    Bootstrap Economics · Seed → Evolve → Revenue → Self-Fund
  </div>
</div>
```

);
