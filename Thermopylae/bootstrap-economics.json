// ═══════════════════════════════════════════════════════════════
// NODE SPECS (what torches build)
// ═══════════════════════════════════════════════════════════════
const NODE_TYPES = {
radiator: { name: “Radiator Node”, al_kg: 1200, build_hrs: 200, compute_kW: 5, cooling_kW: 85, rev_month: 5000 },
compute: { name: “Compute Node”, al_kg: 600, build_hrs: 300, compute_kW: 50, cooling_kW: 25, rev_month: 15000 },
seed: { name: “Seed Factory”, al_kg: 500, build_hrs: 400, compute_kW: 2, cooling_kW: 8, rev_month: 1000 },
};

// ═══════════════════════════════════════════════════════════════
// BOOTSTRAP SIMULATION ENGINE
// ═══════════════════════════════════════════════════════════════
function simulateBootstrap(params, months) {
const timeline = [];

// State
let torches = [{ gen: 0, age_hrs: 0, alive: true }];
let al_stockpile_kg = 0;
let nodes_built = { radiator: 0, compute: 0, seed: 0 };
let total_captured_tons = 0;
let total_revenue = 0;
let total_cost = params.seedCost;
let cumulative_revenue = 0;
let self_funded_month = null;

// Torch evolution tracking
let highestGen = 0;
let genUpgradeTrigger = params.upgradeYieldThreshold;

const hoursPerMonth = 24 * 30 * params.dutyFraction; // operating hours

for (let m = 1; m <= months; m++) {
let monthCut_kg = 0;
let monthPrint_kg = 0;
let monthRevenue = 0;
let torchesBuilt = 0;
let nodesBuiltThisMonth = [];

```
// ── TORCH OPERATIONS ─────────────────────────────────────
const aliveTorches = torches.filter(t => t.alive);
const bestGen = Math.max(...aliveTorches.map(t => t.gen));

for (const torch of aliveTorches) {
  const spec = TORCH_GENS[torch.gen];

  // Cut phase
  const cutHrs = hoursPerMonth * 0.6; // 60% cutting
  const cut_kg = spec.cutRate_kghr * cutHrs;
  const usable_kg = cut_kg * spec.yield;
  monthCut_kg += cut_kg;
  al_stockpile_kg += usable_kg;
  total_captured_tons += cut_kg / 1000;

  // Aging
  torch.age_hrs += hoursPerMonth;
  if (torch.age_hrs > spec.nozzleLife_hrs) {
    // Nozzle death — recycle 60% of torch mass
    torch.alive = false;
    al_stockpile_kg += spec.mass_kg * 0.6;
  }
}

// ── EVOLUTION CHECK ──────────────────────────────────────
// Average yield across fleet — if high enough, trigger upgrade
const fleetYield = aliveTorches.length > 0
  ? aliveTorches.reduce((s, t) => s + TORCH_GENS[t.gen].yield, 0) / aliveTorches.length
  : 0;

if (fleetYield > genUpgradeTrigger && highestGen < 3) {
  highestGen = Math.min(3, highestGen + 1);
  genUpgradeTrigger = Math.min(0.95, genUpgradeTrigger + 0.05);
}

// ── BUILD PHASE ──────────────────────────────────────────
const printingTorches = aliveTorches.filter(t => TORCH_GENS[t.gen].canPrint);
const printHrs = hoursPerMonth * 0.4; // 40% printing

for (const torch of printingTorches) {
  const spec = TORCH_GENS[torch.gen];
  const printCapacity_kg = spec.printRate_kghr * printHrs;

  // Priority: more torches first (if few), then nodes
  const numAliveTorches = torches.filter(t => t.alive).length;

  if (numAliveTorches < params.targetTorchCount && al_stockpile_kg > TORCH_GENS[highestGen].mass_kg * 2) {
    // Build a torch
    const tMass = TORCH_GENS[highestGen].mass_kg;
    if (al_stockpile_kg >= tMass) {
      // Print success rate: Gen 1 = 40%, Gen 2 = 70%, Gen 3 = 90%
      const successRate = 0.3 + highestGen * 0.2;
      const attempts = Math.ceil(1 / successRate);
      const alNeeded = tMass * attempts;
      if (al_stockpile_kg >= alNeeded) {
        al_stockpile_kg -= alNeeded;
        // Failed prints: recycle 60%
        al_stockpile_kg += tMass * (attempts - 1) * 0.6;
        torches.push({ gen: highestGen, age_hrs: 0, alive: true });
        torchesBuilt++;
      }
    }
  } else if (al_stockpile_kg > 1500) {
    // Build a node
    // Prefer compute if we have chip reflow capability
    let nodeType;
    if (spec.canReflow && nodes_built.compute < nodes_built.radiator * 2) {
      nodeType = "compute";
    } else if (nodes_built.seed < Math.floor((nodes_built.radiator + nodes_built.compute) / 8)) {
      nodeType = "seed";
    } else {
      nodeType = "radiator";
    }

    const nodeSpec = NODE_TYPES[nodeType];
    if (al_stockpile_kg >= nodeSpec.al_kg && printCapacity_kg >= nodeSpec.al_kg * 0.5) {
      al_stockpile_kg -= nodeSpec.al_kg;
      nodes_built[nodeType]++;
      nodesBuiltThisMonth.push(nodeType);
    }
  }
}

// ── REVENUE ──────────────────────────────────────────────
for (const [type, count] of Object.entries(nodes_built)) {
  monthRevenue += NODE_TYPES[type].rev_month * count;
}
// Debris cleanup credits
monthRevenue += total_captured_tons * params.debrisCredit_per_ton * 0.01;

total_revenue += monthRevenue;
cumulative_revenue += monthRevenue;

// Self-funding check
if (cumulative_revenue >= total_cost && self_funded_month === null) {
  self_funded_month = m;
}

// Monthly costs (ground ops, insurance, etc)
const monthlyCost = params.monthlyOps;
total_cost += monthlyCost;

// ── RECORD ───────────────────────────────────────────────
const totalNodes = nodes_built.radiator + nodes_built.compute + nodes_built.seed;
const totalCompute = nodes_built.compute * NODE_TYPES.compute.compute_kW +
  nodes_built.radiator * NODE_TYPES.radiator.compute_kW +
  nodes_built.seed * NODE_TYPES.seed.compute_kW;
const totalCooling = nodes_built.compute * NODE_TYPES.compute.cooling_kW +
  nodes_built.radiator * NODE_TYPES.radiator.cooling_kW +
  nodes_built.seed * NODE_TYPES.seed.cooling_kW;
const totalRadArea = nodes_built.radiator * 500 + nodes_built.compute * 150 + nodes_built.seed * 50;

timeline.push({
  month: m,
  torches_alive: torches.filter(t => t.alive).length,
  torches_total: torches.length,
  highest_gen: highestGen,
  fleet_yield: fleetYield,
  al_stockpile: al_stockpile_kg,
  monthCut_kg,
  total_captured_tons,
  nodes_radiator: nodes_built.radiator,
  nodes_compute: nodes_built.compute,
  nodes_seed: nodes_built.seed,
  totalNodes,
  totalCompute,
  totalCooling,
  totalRadArea,
  monthRevenue,
  cumRevenue: cumulative_revenue,
  totalCost: total_cost,
  netPosition: cumulative_revenue - total_cost,
  self_funded: self_funded_month !== null,
  torchesBuilt,
  nodesBuilt: nodesBuiltThisMonth,
  roi_pct: total_cost > 0 ? ((cumulative_revenue / total_cost) - 1) * 100 : 0,
});
```

}

return { timeline, self_funded_month };
}

// ═══════════════════════════════════════════════════════════════
// UI
// ═══════════════════════════════════════════════════════════════
const fmt = (n, d = 1) => {
if (!isFinite(n)) return “∞”;
const a = Math.abs(n);
if (a >= 1e9) return (n / 1e9).toFixed(d) + “B”;
if (a >= 1e6) return (n / 1e6).toFixed(d) + “M”;
if (a >= 1e3) return (n / 1e3).toFixed(d) + “k”;
return n.toFixed(d);
};
const f$ = n => {
if (Math.abs(n) >= 1e9) return “$” + (n / 1e9).toFixed(1) + “B”;
if (Math.abs(n) >= 1e6) return “$” + (n / 1e6).toFixed(1) + “M”;
if (Math.abs(n) >= 1e3) return “$” + (n / 1e3).toFixed(1) + “k”;
return “$” + n.toFixed(0);
};
const fW = w => w >= 1e3 ? (w / 1e3).toFixed(1) + “ MW” : w.toFixed(0) + “ kW”;

function Chart({ data, yKey, label, color, maxH = 70, showZero, f }) {
if (data.length < 2) return null;
const vals = data.map(d => d[yKey]);
const minV = showZero ? Math.min(0, …vals) : Math.min(…vals);
const maxV = Math.max(…vals, 1);
const range = maxV - minV || 1;
const W = 310, H = maxH, P = 3;
const formatter = f || fmt;
return (
<div style={{ marginBottom: 6 }}>
<div style={{ display: “flex”, justifyContent: “space-between”, fontSize: 8, color: “#4a6a7a”, marginBottom: 2 }}>
<span style={{ color }}>{label}</span>
<span>{formatter(vals[vals.length - 1])}</span>
</div>
<svg viewBox={`0 0 ${W} ${H}`} style={{ width: “100%”, maxWidth: 350, height: “auto” }}>
{showZero && minV < 0 && (
<line x1={P} x2={W - P}
y1={H - P - (-minV / range) * (H - P * 2)}
y2={H - P - (-minV / range) * (H - P * 2)}
stroke=”#ffffff20” strokeWidth={0.5} strokeDasharray=“4,4” />
)}
<path d={
data.map((d, i) => {
const x = P + (i / (data.length - 1)) * (W - P * 2);
const y = H - P - ((d[yKey] - minV) / range) * (H - P * 2);
return `${i === 0 ? "M" : "L"}${x},${y}`;
}).join(” “) + ` L${W - P},${H - P} L${P},${H - P} Z`
} fill={`${color}12`} />
<path d={
data.map((d, i) => {
const x = P + (i / (data.length - 1)) * (W - P * 2);
const y = H - P - ((d[yKey] - minV) / range) * (H - P * 2);
return `${i === 0 ? "M" : "L"}${x},${y}`;
}).join(” “)
} fill=“none” stroke={color} strokeWidth={1.5} />
</svg>
</div>
);
}

function Sl({ k, label, unit, min, max, step, value, onChange, accent = “#00ccaa” }) {
return (
<div style={{ marginBottom: 7 }}>
<div style={{ display: “flex”, justifyContent: “space-between”, marginBottom: 1 }}>
<span style={{ fontSize: 9, color: “#5a7a8a” }}>{label}</span>
<span style={{ fontSize: 9, color: accent, fontWeight: 600 }}>
{Number.isInteger(step) && step >= 1 ? value : value.toFixed(2)}{unit ? ` ${unit}` : “”}
</span>
</div>
<input type=“range” min={min} max={max} step={step} value={value}
onChange={e => onChange(k, parseFloat(e.target.value))}
style={{ width: “100%”, height: 18, accentColor: accent, cursor: “pointer” }} />
</div>
);
}

