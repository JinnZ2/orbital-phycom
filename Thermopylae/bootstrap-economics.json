// ═══════════════════════════════════════════════════════════════
// TORCH GENERATION SPECS
// ═══════════════════════════════════════════════════════════════
const TORCH_GENS = [
{
gen: 0, name: “Seed Torch”, mass_kg: 30, power_kW: 5,
cutRate_kghr: 1, yield: 0.70, nozzleLife_hrs: 200,
printRate_kghr: 0, canPrint: false, canReflow: false,
cost_launched: 500000, // $500k for first seed torch
notes: “Launched. W cathode + scrap Al anode. Ar vortex.”,
},
{
gen: 1, name: “Self-Forged”, mass_kg: 25, power_kW: 15,
cutRate_kghr: 5, yield: 0.80, nozzleLife_hrs: 500,
printRate_kghr: 2, canPrint: true, canReflow: false,
cost_launched: 0, // built from junk
notes: “Al+WC nozzle. IR tracking. Slag → radiator panels.”,
},
{
gen: 2, name: “Swarm-Spec”, mass_kg: 20, power_kW: 25,
cutRate_kghr: 20, yield: 0.88, nozzleLife_hrs: 1000,
printRate_kghr: 8, canPrint: true, canReflow: true,
